# 服务配置
NODE_ENV=production
PORT=3000

# 数据库类型: sqlite 或 mysql
DB_TYPE=sqlite

# SQLite 配置 (当 DB_TYPE=sqlite 时使用)
DB_STORAGE=/app/dist/data/data.db

# MySQL 配置 (当 DB_TYPE=mysql 时使用)
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=koa_app
# DB_USER=root
# DB_PASSWORD=

# 数据库日志 (true/false)
DB_LOGGING=false

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# 数据目录
DATA_DIR=/app/dist/data

# 默认管理员账户
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=a123456.
